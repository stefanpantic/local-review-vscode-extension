{
  "name": "local-review",
  "displayName": "Local Review",
  "description": "PR-style review of your local git diff, exported for a coding agent.",
  "version": "0.0.2",
  "publisher": "local",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/stefanpantic/local-review-vscode-extension.git"
  },
  "bugs": {
    "url": "https://github.com/stefanpantic/local-review-vscode-extension/issues"
  },
  "homepage": "https://github.com/stefanpantic/local-review-vscode-extension#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./dist/extension.js",
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "localReview",
          "title": "Local Review",
          "icon": "media/local-review.svg"
        }
      ]
    },
    "views": {
      "localReview": [
        {
          "id": "localReview.files",
          "name": "Changes"
        },
        {
          "id": "localReview.comments",
          "name": "Active Review Comments"
        },
        {
          "id": "localReview.reviews",
          "name": "Saved Reviews"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "localReview.files",
        "when": "localReview.emptyReason == no-repo",
        "contents": "No Git repository in this workspace.\nOpen a folder that is a Git repository to review its changes."
      },
      {
        "view": "localReview.files",
        "when": "localReview.emptyReason == unborn-head",
        "contents": "This repository has no commits yet. Nothing is staged or tracked to review."
      },
      {
        "view": "localReview.files",
        "when": "localReview.emptyReason == error",
        "contents": "Couldn't read the diff.\n[Retry](command:localReview.refresh)"
      },
      {
        "view": "localReview.files",
        "when": "localReview.emptyReason == no-changes && localReview.source == staged",
        "contents": "No staged changes.\n[Change source](command:localReview.selectSource)"
      },
      {
        "view": "localReview.files",
        "when": "localReview.emptyReason == no-changes && localReview.source == unstaged",
        "contents": "No unstaged changes.\n[Change source](command:localReview.selectSource)"
      },
      {
        "view": "localReview.files",
        "when": "localReview.emptyReason == no-changes && localReview.source == worktree-vs-head",
        "contents": "No uncommitted changes.\n[Change source](command:localReview.selectSource)"
      },
      {
        "view": "localReview.files",
        "when": "localReview.emptyReason == no-changes && localReview.source == vs-base",
        "contents": "No changes compared with the base branch.\n[Change source](command:localReview.selectSource)"
      },
      {
        "view": "localReview.comments",
        "contents": "No comments in the active review yet.\nHover a line in the diff and click + to add one."
      },
      {
        "view": "localReview.reviews",
        "contents": "No reviews yet.\nComment on the diff (a review is created automatically), or use New Review to start one."
      }
    ],
    "commands": [
      {
        "command": "localReview.startReview",
        "title": "Start a Review",
        "category": "Local Review",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "localReview.refresh",
        "title": "Refresh",
        "category": "Local Review",
        "icon": "$(refresh)"
      },
      {
        "command": "localReview.selectSource",
        "title": "Select Diff Source",
        "category": "Local Review",
        "icon": "$(git-compare)"
      },
      {
        "command": "localReview.selectRepo",
        "title": "Select Repository",
        "category": "Local Review",
        "icon": "$(repo)"
      },
      {
        "command": "localReview.revealFile",
        "title": "Reveal File",
        "category": "Local Review"
      },
      {
        "command": "localReview.toggleViewMode",
        "title": "Toggle Split / Unified View",
        "category": "Local Review"
      },
      {
        "command": "localReview.toggleWhitespace",
        "title": "Toggle Hide Whitespace",
        "category": "Local Review"
      },
      {
        "command": "localReview.newReview",
        "title": "New Review",
        "category": "Local Review",
        "icon": "$(add)"
      },
      {
        "command": "localReview.switchReview",
        "title": "Switch to Review",
        "category": "Local Review"
      },
      {
        "command": "localReview.renameReview",
        "title": "Rename Review",
        "category": "Local Review",
        "icon": "$(pencil)"
      },
      {
        "command": "localReview.deleteReview",
        "title": "Delete Review",
        "category": "Local Review",
        "icon": "$(trash)"
      },
      {
        "command": "localReview.moveReviewToCurrentBranch",
        "title": "Move to Current Branch",
        "category": "Local Review",
        "icon": "$(arrow-right)"
      },
      {
        "command": "localReview.exportReview",
        "title": "Export Review",
        "category": "Local Review",
        "icon": "$(export)"
      },
      {
        "command": "localReview.nextChange",
        "title": "Next Changed File",
        "category": "Local Review"
      },
      {
        "command": "localReview.prevChange",
        "title": "Previous Changed File",
        "category": "Local Review"
      },
      {
        "command": "localReview.nextComment",
        "title": "Next Comment",
        "category": "Local Review"
      },
      {
        "command": "localReview.prevComment",
        "title": "Previous Comment",
        "category": "Local Review"
      },
      {
        "command": "localReview.setupMcp",
        "title": "Set up MCP",
        "category": "Local Review",
        "icon": "$(plug)"
      },
      {
        "command": "localReview.startMcp",
        "title": "Start MCP Server",
        "category": "Local Review",
        "icon": "$(play)"
      },
      {
        "command": "localReview.stopMcp",
        "title": "Stop MCP Server",
        "category": "Local Review",
        "icon": "$(debug-stop)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "localReview.startReview",
          "when": "view == localReview.files",
          "group": "navigation@1"
        },
        {
          "command": "localReview.selectSource",
          "when": "view == localReview.files",
          "group": "navigation@2"
        },
        {
          "command": "localReview.selectRepo",
          "when": "view == localReview.files",
          "group": "navigation@3"
        },
        {
          "command": "localReview.refresh",
          "when": "view == localReview.files",
          "group": "navigation@4"
        },
        {
          "command": "localReview.newReview",
          "when": "view == localReview.reviews",
          "group": "navigation@1"
        },
        {
          "command": "localReview.exportReview",
          "when": "view == localReview.comments",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "localReview.exportReview",
          "when": "view == localReview.reviews && viewItem =~ /^localReview.review/",
          "group": "export@1"
        },
        {
          "command": "localReview.moveReviewToCurrentBranch",
          "when": "view == localReview.reviews && viewItem == localReview.review.other",
          "group": "inline@1"
        },
        {
          "command": "localReview.renameReview",
          "when": "view == localReview.reviews && viewItem =~ /^localReview.review/",
          "group": "inline@2"
        },
        {
          "command": "localReview.deleteReview",
          "when": "view == localReview.reviews && viewItem =~ /^localReview.review/",
          "group": "inline@3"
        }
      ],
      "editor/title": [
        {
          "command": "localReview.exportReview",
          "when": "activeWebviewPanelId == localReview.panel",
          "group": "navigation@1"
        },
        {
          "command": "localReview.refresh",
          "when": "activeWebviewPanelId == localReview.panel",
          "group": "navigation@2"
        }
      ],
      "commandPalette": [
        {
          "command": "localReview.revealFile",
          "when": "false"
        },
        {
          "command": "localReview.switchReview",
          "when": "false"
        },
        {
          "command": "localReview.renameReview",
          "when": "false"
        },
        {
          "command": "localReview.deleteReview",
          "when": "false"
        },
        {
          "command": "localReview.moveReviewToCurrentBranch",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "localReview.renameReview",
        "key": "f2",
        "when": "focusedView == localReview.reviews"
      },
      {
        "command": "localReview.nextChange",
        "key": "alt+down",
        "when": "activeWebviewPanelId == localReview.panel"
      },
      {
        "command": "localReview.prevChange",
        "key": "alt+up",
        "when": "activeWebviewPanelId == localReview.panel"
      },
      {
        "command": "localReview.nextComment",
        "key": "alt+shift+down",
        "when": "activeWebviewPanelId == localReview.panel"
      },
      {
        "command": "localReview.prevComment",
        "key": "alt+shift+up",
        "when": "activeWebviewPanelId == localReview.panel"
      }
    ],
    "configuration": {
      "title": "Local Review",
      "properties": {
        "localReview.defaultSource": {
          "type": "string",
          "enum": [
            "worktree-vs-head",
            "unstaged",
            "staged",
            "vs-base"
          ],
          "default": "worktree-vs-head",
          "description": "Default diff source when a review is first opened."
        },
        "localReview.defaultViewMode": {
          "type": "string",
          "enum": [
            "unified",
            "split"
          ],
          "default": "unified",
          "description": "Default diff rendering mode."
        },
        "localReview.defaultHideWhitespace": {
          "type": "boolean",
          "default": false,
          "description": "Hide whitespace-only changes by default (git diff -w)."
        },
        "localReview.log": {
          "type": "boolean",
          "default": false,
          "description": "Write diagnostic logs to the 'Local Review' output channel."
        },
        "localReview.includeUntracked": {
          "type": "boolean",
          "default": true,
          "description": "Include untracked files (shown as all-addition entries; .gitignored files are excluded)."
        },
        "localReview.largeFileThreshold": {
          "type": "number",
          "default": 1000,
          "description": "Files with more than this many changed lines start collapsed."
        },
        "localReview.contextLines": {
          "type": "number",
          "default": 3,
          "description": "Lines of surrounding context captured for comments and export (used from Iteration 4)."
        },
        "localReview.mcp.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Start the local MCP server automatically when VS Code launches, so a coding agent (e.g. Claude Code) can read the diff and post, reply to, and resolve review comments. Otherwise start it with the 'Local Review: Start MCP Server' command. Binds to 127.0.0.1 only."
        },
        "localReview.mcp.port": {
          "type": "number",
          "default": 0,
          "description": "Port for the MCP server (0 picks a free port, then reuses it across restarts). Set a fixed port for a guaranteed-stable URL."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "parse-diff": "^0.11.1",
    "shiki": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.31.0",
    "esbuild": "^0.23.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "tsx": "^4.16.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
