{
  "name": "local-review",
  "displayName": "Local Review",
  "description": "PR-style review of your local git diff, exported for a coding agent.",
  "version": "0.0.1",
  "publisher": "local",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./dist/extension.js",
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "localReview",
          "title": "Local Review",
          "icon": "media/local-review.svg"
        }
      ]
    },
    "views": {
      "localReview": [
        {
          "id": "localReview.files",
          "name": "Changes"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "localReview.files",
        "contents": "Review your local changes as a pull request.\n[Start a Review](command:localReview.startReview)"
      }
    ],
    "commands": [
      {
        "command": "localReview.startReview",
        "title": "Start a Review",
        "category": "Local Review",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "localReview.refresh",
        "title": "Refresh",
        "category": "Local Review",
        "icon": "$(refresh)"
      },
      {
        "command": "localReview.selectSource",
        "title": "Select Diff Source",
        "category": "Local Review",
        "icon": "$(git-compare)"
      },
      {
        "command": "localReview.selectRepo",
        "title": "Select Repository",
        "category": "Local Review",
        "icon": "$(repo)"
      },
      {
        "command": "localReview.revealFile",
        "title": "Reveal File",
        "category": "Local Review"
      }
    ],
    "menus": {
      "view/title": [
        { "command": "localReview.startReview", "when": "view == localReview.files", "group": "navigation@1" },
        { "command": "localReview.selectSource", "when": "view == localReview.files", "group": "navigation@2" },
        { "command": "localReview.selectRepo", "when": "view == localReview.files", "group": "navigation@3" },
        { "command": "localReview.refresh", "when": "view == localReview.files", "group": "navigation@4" }
      ],
      "commandPalette": [
        { "command": "localReview.revealFile", "when": "false" }
      ]
    },
    "configuration": {
      "title": "Local Review",
      "properties": {
        "localReview.defaultSource": {
          "type": "string",
          "enum": ["worktree-vs-head", "unstaged", "staged", "vs-base"],
          "default": "worktree-vs-head",
          "description": "Default diff source when a review is first opened."
        },
        "localReview.includeUntracked": {
          "type": "boolean",
          "default": false,
          "description": "Include untracked files (shown as all-addition entries)."
        },
        "localReview.largeFileThreshold": {
          "type": "number",
          "default": 1000,
          "description": "Files with more than this many changed lines start collapsed."
        },
        "localReview.contextLines": {
          "type": "number",
          "default": 3,
          "description": "Lines of surrounding context captured for comments and export (used from Iteration 4)."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "parse-diff": "^0.11.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.31.0",
    "esbuild": "^0.23.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.62.1"
  }
}
