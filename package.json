{
  "name": "local-review",
  "displayName": "Local Review",
  "description": "PR-style review of your local git diff, exported for a coding agent.",
  "version": "0.0.1",
  "publisher": "local",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./dist/extension.js",
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "localReview",
          "title": "Local Review",
          "icon": "media/local-review.svg"
        }
      ]
    },
    "views": {
      "localReview": [
        {
          "id": "localReview.files",
          "name": "Changes"
        },
        {
          "id": "localReview.comments",
          "name": "Comments"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "localReview.files",
        "when": "localReview.emptyReason == no-repo",
        "contents": "No Git repository in this workspace.\nOpen a folder that is a Git repository to review its changes."
      },
      {
        "view": "localReview.files",
        "when": "localReview.emptyReason == unborn-head",
        "contents": "This repository has no commits yet — nothing staged or tracked to review."
      },
      {
        "view": "localReview.files",
        "when": "localReview.emptyReason == error",
        "contents": "Couldn't read the diff.\n[Retry](command:localReview.refresh)"
      },
      {
        "view": "localReview.files",
        "when": "localReview.emptyReason == no-changes && localReview.source == staged",
        "contents": "No staged changes.\n[Change source](command:localReview.selectSource)"
      },
      {
        "view": "localReview.files",
        "when": "localReview.emptyReason == no-changes && localReview.source == unstaged",
        "contents": "No unstaged changes.\n[Change source](command:localReview.selectSource)"
      },
      {
        "view": "localReview.files",
        "when": "localReview.emptyReason == no-changes && localReview.source == worktree-vs-head",
        "contents": "No uncommitted changes.\n[Change source](command:localReview.selectSource)"
      },
      {
        "view": "localReview.files",
        "when": "localReview.emptyReason == no-changes && localReview.source == vs-base",
        "contents": "No changes compared with the base branch.\n[Change source](command:localReview.selectSource)"
      },
      {
        "view": "localReview.comments",
        "contents": "No comments in this review yet.\nHover a line in the diff and click + to start one."
      }
    ],
    "commands": [
      {
        "command": "localReview.startReview",
        "title": "Start a Review",
        "category": "Local Review",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "localReview.refresh",
        "title": "Refresh",
        "category": "Local Review",
        "icon": "$(refresh)"
      },
      {
        "command": "localReview.selectSource",
        "title": "Select Diff Source",
        "category": "Local Review",
        "icon": "$(git-compare)"
      },
      {
        "command": "localReview.selectRepo",
        "title": "Select Repository",
        "category": "Local Review",
        "icon": "$(repo)"
      },
      {
        "command": "localReview.revealFile",
        "title": "Reveal File",
        "category": "Local Review"
      },
      {
        "command": "localReview.toggleViewMode",
        "title": "Toggle Split / Unified View",
        "category": "Local Review"
      },
      {
        "command": "localReview.toggleWhitespace",
        "title": "Toggle Hide Whitespace",
        "category": "Local Review"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "localReview.startReview",
          "when": "view == localReview.files",
          "group": "navigation@1"
        },
        {
          "command": "localReview.selectSource",
          "when": "view == localReview.files",
          "group": "navigation@2"
        },
        {
          "command": "localReview.selectRepo",
          "when": "view == localReview.files",
          "group": "navigation@3"
        },
        {
          "command": "localReview.refresh",
          "when": "view == localReview.files",
          "group": "navigation@4"
        }
      ],
      "commandPalette": [
        {
          "command": "localReview.revealFile",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Local Review",
      "properties": {
        "localReview.defaultSource": {
          "type": "string",
          "enum": [
            "worktree-vs-head",
            "unstaged",
            "staged",
            "vs-base"
          ],
          "default": "worktree-vs-head",
          "description": "Default diff source when a review is first opened."
        },
        "localReview.defaultViewMode": {
          "type": "string",
          "enum": [
            "unified",
            "split"
          ],
          "default": "unified",
          "description": "Default diff rendering mode."
        },
        "localReview.defaultHideWhitespace": {
          "type": "boolean",
          "default": false,
          "description": "Hide whitespace-only changes by default (git diff -w)."
        },
        "localReview.log": {
          "type": "boolean",
          "default": false,
          "description": "Write diagnostic logs to the 'Local Review' output channel."
        },
        "localReview.includeUntracked": {
          "type": "boolean",
          "default": false,
          "description": "Include untracked files (shown as all-addition entries)."
        },
        "localReview.largeFileThreshold": {
          "type": "number",
          "default": 1000,
          "description": "Files with more than this many changed lines start collapsed."
        },
        "localReview.contextLines": {
          "type": "number",
          "default": 3,
          "description": "Lines of surrounding context captured for comments and export (used from Iteration 4)."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "parse-diff": "^0.11.1",
    "shiki": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.31.0",
    "esbuild": "^0.23.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.62.1"
  }
}
